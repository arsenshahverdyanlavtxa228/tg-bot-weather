# Telegram bot token — @BotFather → /newbot
BOT_TOKEN=123456:your-bot-token-here

# OpenWeather API key — https://openweathermap.org/api (free tier is enough)
# After signup the key takes up to ~10 minutes to activate.
OPENWEATHER_API_KEY=your-openweather-api-key

# SQLite path (inside container mapped to /app/data/bot.db via docker volume)
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# Default UI language: ru | en
DEFAULT_LOCALE=ru

# Default units: metric (°C, m/s) | imperial (°F, mph)
DEFAULT_UNITS=metric

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Drop pending updates on startup
DROP_PENDING_UPDATES=false

# Cache TTL for weather responses (seconds). Helps you stay under free-tier rate limits.
WEATHER_CACHE_TTL=300
